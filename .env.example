PORT=3000

# Optional: use env vars instead of keycloak-config.json
KEYCLOAK_REALM=api-realm
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8080
KEYCLOAK_SSL_REQUIRED=external
KEYCLOAK_RESOURCE=api-personne
KEYCLOAK_CLIENT_SECRET=replace-with-your-client-secret
KEYCLOAK_BEARER_ONLY=true
KEYCLOAK_CONFIDENTIAL_PORT=0
